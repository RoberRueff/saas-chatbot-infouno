# Google Gemini — obtené tu clave en https://aistudio.google.com/app/apikey
GEMINI_API_KEY=tu_clave_aqui

# App settings
APP_ENV=development
APP_PORT=8000
APP_SECRET_KEY=cambia_esta_clave_secreta

# Twilio — validación de firma del webhook de WhatsApp
# Si TWILIO_AUTH_TOKEN está vacío, la validación se DESACTIVA (modo desarrollo).
# En producción es obligatorio para evitar webhooks falsos y abuso de la IA.
TWILIO_AUTH_TOKEN=
# Opcional: forzar la URL pública exacta del webhook. Si se deja vacío, se
# reconstruye desde los headers del request (sirve para ngrok).
# TWILIO_WEBHOOK_URL=https://tu-subdominio.ngrok-free.app/whatsapp
